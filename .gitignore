# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you probably want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates think lock file should not be tracked:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be tracked
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be tracked
#pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

